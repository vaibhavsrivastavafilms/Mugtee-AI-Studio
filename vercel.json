{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/generate-script/route.ts": {
      "maxDuration": 300
    },
    "app/api/ai/deep-research/route.ts": {
      "maxDuration": 120
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://mugtee.in/:path*",
      "statusCode": 301,
      "has": [
        {
          "type": "host",
          "value": "www.mugtee.in"
        }
      ]
    }
  ]
}
