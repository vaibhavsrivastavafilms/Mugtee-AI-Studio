# =============================================================================
# Mugtee AI Studio — environment variables
# Copy to .env.local for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables.
# NEVER commit .env.local.
# =============================================================================

# --- Site / deployment ---
# NEXT_PUBLIC_BASE_URL=https://mugtee.in
# NEXT_PUBLIC_APP_URL=https://mugtee.in
# NEXT_OUTPUT_STANDALONE=1          # Docker/Linux self-hosted only (disabled on Vercel + Windows builds)

# =============================================================================
# Quick Cut FREE TIER (recommended for local dev)
# =============================================================================
# Set FREE_TIER_ONLY=true to block paid providers (Claude, DALL-E, ElevenLabs,
# Emergent gateway). Pipeline still runs end-to-end with mocks when keys are missing.
#
# Minimum for live free generation:
#   GEMINI_API_KEY — https://aistudio.google.com/apikey (free quota on Flash models)
#
# Optional (still low-cost; not required for free-only):
#   PERPLEXITY_API_KEY — Sonar deep research (preferred when set)
#   OPENAI_API_KEY — gpt-4o-mini script generation + tts-1 voice
# =============================================================================

FREE_TIER_ONLY=true

# Google AI Studio (free tier) — script + scene images via generativelanguage.googleapis.com
GEMINI_API_KEY=
# GOOGLE_API_KEY=              # alias for GEMINI_API_KEY
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Perplexity Sonar — cinematic deep research (used before OpenAI/Gemini when set)
# https://docs.perplexity.ai/
# PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar-pro

# OpenAI ChatGPT — cinematic script generation (preferred when set; not used for research if Perplexity is set)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=gpt-image-1   # fallback when Gemini fails; dall-e-3 is deprecated on new keys

# --- Paid providers (ignored when FREE_TIER_ONLY=true) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# EMERGENT_LLM_KEY=
# EMERGENT_API_BASE=
# EMERGENT_GEMINI_IMAGE_MODEL=gemini/gemini-2.5-flash-image
# ElevenLabs — cinematic voiceover (Quick Cut Voice tab + /api/generate-voice)
# https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# REPLICATE_API_TOKEN=

# Supabase (required for auth + asset storage — must also be set in Vercel project env)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=          # legacy JWT anon key or sb_publishable_* key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # alias accepted by middleware if ANON_KEY is unset
# SUPABASE_SERVICE_ROLE_KEY=

# Video render (optional)
# VIDEO_RENDER_ENABLED=false
# VIDEO_RENDER_MOCK=false
# FFMPEG_PATH=
# FFMPEG_BIN=
# When set, compile uses Runway Gen-4.5 image-to-video per scene (FFmpeg still assembles final MP4).
# RUNWAY_API_KEY=                    # https://dev.runwayml.com/ — alias: RUNWAYML_API_SECRET
# RUNWAY_MODEL=gen4.5
# VIDEO_RENDER_PROVIDER=auto         # auto | runway | ffmpeg
# CINEMATIC_RENDER_PROVIDER=

# Script quality gates (optional)
# SCRIPT_SOP_MIN_SCORE=
# SCRIPT_SOP_MAX_RETRIES=

# --- Auth integrations ---
# YouTube OAuth (Settings → Integrations)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# YOUTUBE_REDIRECT_URI=              # defaults to {NEXT_PUBLIC_BASE_URL}/api/youtube/callback

# Instagram / Meta OAuth
# META_APP_ID=
# META_APP_SECRET=
# INSTAGRAM_APP_ID=                  # alias for META_APP_ID
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_ACCESS_TOKEN=

# --- Billing (Razorpay) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PLAN_CREATOR_ID=
# RAZORPAY_PLAN_AGENCY_ID=

# --- Analytics & ads ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_ADSENSE_CLIENT=

# --- Admin ---
# ADMIN_USER_IDS=                    # comma-separated Supabase user UUIDs
# ADMIN_EMAILS=

# --- Sales / contact ---
# NEXT_PUBLIC_AGENCY_WHATSAPP=

# --- Legacy Mongo catch-all API (app/api/[[...path]]) ---
# MONGO_URL=
# DB_NAME=
# CORS_ORIGINS=*
